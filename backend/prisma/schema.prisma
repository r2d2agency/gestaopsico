generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Plan {
  id               String         @id @default(uuid()) @db.Uuid
  name             String         @db.VarChar(100)
  slug             String         @unique @db.VarChar(50)
  description      String?
  price            Decimal        @db.Decimal(10, 2)
  priceWithAi      Decimal?       @map("price_with_ai") @db.Decimal(10, 2)
  maxPatients      Int            @default(10) @map("max_patients")
  maxUsers         Int            @default(1) @map("max_users")
  maxPsychologists Int            @default(1) @map("max_psychologists")
  trialDays        Int            @default(7) @map("trial_days")
  hasAiSecretary   Boolean        @default(false) @map("has_ai_secretary")
  hasWhatsapp      Boolean        @default(false) @map("has_whatsapp")
  isRecommended    Boolean        @default(false) @map("is_recommended")
  isActive         Boolean        @default(true) @map("is_active")
  features         String[]       @default([])
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  organizations    Organization[]

  @@map("plans")
}

model Organization {
  id            String         @id @default(uuid()) @db.Uuid
  name          String         @db.VarChar(255)
  slug          String         @unique @db.VarChar(100)
  type          String         @default("clinic") @db.VarChar(20)
  planId        String?        @map("plan_id") @db.Uuid
  planRef       Plan?          @relation(fields: [planId], references: [id])
  plan          String         @default("basic") @db.VarChar(50)
  status        String         @default("active") @db.VarChar(20)
  maxUsers      Int            @default(1) @map("max_users")
  phone         String?        @db.VarChar(20)
  email         String?        @db.VarChar(255)
  cnpj          String?        @db.VarChar(18)
  address       String?
  logo          String?
  trialEndsAt   DateTime?      @map("trial_ends_at")
  suspendedAt   DateTime?      @map("suspended_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  users         User[]
  subscriptions Subscription[]
  providerKeys  AiProviderKey[]

  @@map("organizations")
}

model Subscription {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan           String       @db.VarChar(50)
  status         String       @default("active") @db.VarChar(20)
  startDate      DateTime     @map("start_date")
  endDate        DateTime?    @map("end_date")
  value          Decimal      @db.Decimal(10, 2)
  createdAt      DateTime     @default(now()) @map("created_at")

  @@map("subscriptions")
}

model User {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id])
  name           String        @db.VarChar(255)
  email          String        @unique @db.VarChar(255)
  passwordHash   String        @map("password_hash") @db.VarChar(255)
  role           String        @default("professional") @db.VarChar(50)
  status         String        @default("active") @db.VarChar(20)
  createdAt      DateTime      @default(now()) @map("created_at")
  patients       Patient[]
  couples        Couple[]
  appointments   Appointment[]
  records        Record[]
  createdAgents  AiAgent[]     @relation("agentCreator")
  customizations AiAgentCustomization[] @relation("agentCustomizations")
  providerKeys   AiProviderKey[]        @relation("providerKeys")
  aiChats        AiChat[]               @relation("aiChats")
  secretaryConfigs SecretaryConfig[]

  @@map("users")
}

model WhatsappInstance {
  id             String         @id @default(uuid()) @db.Uuid
  instanceId     String         @unique @map("instance_id") @db.VarChar(255)
  instanceName   String         @map("instance_name") @db.VarChar(255)
  phone          String?        @db.VarChar(20)
  status         String         @default("disconnected") @db.VarChar(20)
  organizationId String?        @map("organization_id") @db.Uuid
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  secretaryConfigs SecretaryConfig[]
  notifications  WhatsappNotification[]

  @@map("whatsapp_instances")
}

model SecretaryConfig {
  id              String            @id @default(uuid()) @db.Uuid
  userId          String            @map("user_id") @db.Uuid
  user            User              @relation(fields: [userId], references: [id])
  instanceId      String?           @map("instance_id") @db.Uuid
  instance        WhatsappInstance?  @relation(fields: [instanceId], references: [id])
  secretaryName   String            @default("Secretária Virtual") @map("secretary_name") @db.VarChar(100)
  workingHoursStart String          @default("08:00") @map("working_hours_start") @db.VarChar(5)
  workingHoursEnd String            @default("18:00") @map("working_hours_end") @db.VarChar(5)
  workingDays     String[]          @default(["seg","ter","qua","qui","sex"]) @map("working_days")
  clinicName      String?           @map("clinic_name") @db.VarChar(255)
  clinicAddress   String?           @map("clinic_address")
  clinicPhone     String?           @map("clinic_phone") @db.VarChar(20)
  professionalInfo String?         @map("professional_info")
  promptComplement String?         @map("prompt_complement")
  isActive        Boolean           @default(true) @map("is_active")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@unique([userId])
  @@map("secretary_configs")
}

model WhatsappNotification {
  id             String            @id @default(uuid()) @db.Uuid
  instanceId     String            @map("instance_id") @db.Uuid
  instance       WhatsappInstance   @relation(fields: [instanceId], references: [id])
  phone          String            @db.VarChar(20)
  message        String
  type           String            @db.VarChar(30)
  status         String            @default("queued") @db.VarChar(20)
  scheduledAt    DateTime          @map("scheduled_at")
  sentAt         DateTime?         @map("sent_at")
  error          String?
  referenceId    String?           @map("reference_id") @db.Uuid
  referenceType  String?           @map("reference_type") @db.VarChar(30)
  createdAt      DateTime          @default(now()) @map("created_at")

  @@index([status, scheduledAt])
  @@map("whatsapp_notifications")
}
  name             String        @db.VarChar(255)
  cpf              String?       @unique @db.VarChar(14)
  birthDate        DateTime?     @map("birth_date") @db.Date
  phone            String?       @db.VarChar(20)
  email            String?       @db.VarChar(255)
  address          String?
  gender           String?       @db.VarChar(20)
  emergencyContact String?       @map("emergency_contact") @db.VarChar(255)
  clinicalNotes    String?       @map("clinical_notes")
  healthHistory    String?       @map("health_history")
  medications      String?
  allergies        String?
  status           String        @default("active") @db.VarChar(20)
  createdAt        DateTime      @default(now()) @map("created_at")
  appointments     Appointment[]
  records          Record[]
  payments         Payment[]
  couplesAs1       Couple[]      @relation("patient1")
  couplesAs2       Couple[]      @relation("patient2")

  @@map("patients")
}

model Couple {
  id             String        @id @default(uuid()) @db.Uuid
  professionalId String        @map("professional_id") @db.Uuid
  professional   User          @relation(fields: [professionalId], references: [id])
  patient1Id     String        @map("patient1_id") @db.Uuid
  patient1       Patient       @relation("patient1", fields: [patient1Id], references: [id])
  patient2Id     String        @map("patient2_id") @db.Uuid
  patient2       Patient       @relation("patient2", fields: [patient2Id], references: [id])
  name           String?       @db.VarChar(255)
  createdAt      DateTime      @default(now()) @map("created_at")
  appointments   Appointment[]
  records        Record[]

  @@map("couples")
}

model Appointment {
  id             String         @id @default(uuid()) @db.Uuid
  professionalId String         @map("professional_id") @db.Uuid
  professional   User           @relation(fields: [professionalId], references: [id])
  patientId      String?        @map("patient_id") @db.Uuid
  patient        Patient?       @relation(fields: [patientId], references: [id])
  coupleId       String?        @map("couple_id") @db.Uuid
  couple         Couple?        @relation(fields: [coupleId], references: [id])
  type           String         @db.VarChar(20)
  date           DateTime       @db.Date
  time           String         @db.VarChar(5)
  duration       Int            @default(50)
  value          Decimal?       @db.Decimal(10, 2)
  status         String         @default("scheduled") @db.VarChar(20)
  paymentStatus  String         @default("pending") @map("payment_status") @db.VarChar(20)
  mode           String         @default("video") @db.VarChar(20)
  notes          String?
  createdAt      DateTime       @default(now()) @map("created_at")
  records        Record[]
  transcriptions Transcription[]
  payments       Payment[]

  @@map("appointments")
}

model Record {
  id             String       @id @default(uuid()) @db.Uuid
  appointmentId  String?      @map("appointment_id") @db.Uuid
  appointment    Appointment? @relation(fields: [appointmentId], references: [id])
  patientId      String?      @map("patient_id") @db.Uuid
  patient        Patient?     @relation(fields: [patientId], references: [id])
  coupleId       String?      @map("couple_id") @db.Uuid
  couple         Couple?      @relation(fields: [coupleId], references: [id])
  professionalId String       @map("professional_id") @db.Uuid
  professional   User         @relation(fields: [professionalId], references: [id])
  type           String       @db.VarChar(20)
  content        String?
  aiContent      String?      @map("ai_content")
  date           DateTime     @db.Date
  createdAt      DateTime     @default(now()) @map("created_at")

  @@map("records")
}

model Transcription {
  id            String      @id @default(uuid()) @db.Uuid
  appointmentId String      @map("appointment_id") @db.Uuid
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  content       String?
  speakers      Json?
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("transcriptions")
}

model Payment {
  id            String       @id @default(uuid()) @db.Uuid
  appointmentId String?      @map("appointment_id") @db.Uuid
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  patientId     String       @map("patient_id") @db.Uuid
  patient       Patient      @relation(fields: [patientId], references: [id])
  value         Decimal      @db.Decimal(10, 2)
  method        String?      @db.VarChar(20)
  status        String       @default("pending") @db.VarChar(20)
  paidAt        DateTime?    @map("paid_at")
  createdAt     DateTime     @default(now()) @map("created_at")

  @@map("payments")
}

model SystemSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(100)
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model AiAgent {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @db.VarChar(255)
  description    String?
  systemPrompt   String   @map("system_prompt")
  capabilities   String[] @default([])
  category       String   @default("general") @db.VarChar(50)
  defaultModel   String   @default("gemini") @map("default_model") @db.VarChar(50)
  isActive       Boolean  @default(true) @map("is_active")
  createdBy      String   @map("created_by") @db.Uuid
  creator        User     @relation("agentCreator", fields: [createdBy], references: [id])
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  customizations AiAgentCustomization[]
  chats          AiChat[]

  @@map("ai_agents")
}

model AiAgentCustomization {
  id              String   @id @default(uuid()) @db.Uuid
  agentId         String   @map("agent_id") @db.Uuid
  agent           AiAgent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  userId          String   @map("user_id") @db.Uuid
  user            User     @relation("agentCustomizations", fields: [userId], references: [id])
  additionalPrompt String? @map("additional_prompt")
  preferredModel  String?  @map("preferred_model") @db.VarChar(50)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([agentId, userId])
  @@map("ai_agent_customizations")
}

model AiProviderKey {
  id             String        @id @default(uuid()) @db.Uuid
  provider       String        @db.VarChar(50)
  apiKey         String        @map("api_key")
  isGlobal       Boolean       @default(false) @map("is_global")
  organizationId String?       @map("organization_id") @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id])
  userId         String?       @map("user_id") @db.Uuid
  user           User?         @relation("providerKeys", fields: [userId], references: [id])
  createdAt      DateTime      @default(now()) @map("created_at")

  @@map("ai_provider_keys")
}

model AiChat {
  id        String          @id @default(uuid()) @db.Uuid
  agentId   String          @map("agent_id") @db.Uuid
  agent     AiAgent         @relation(fields: [agentId], references: [id])
  userId    String          @map("user_id") @db.Uuid
  user      User            @relation("aiChats", fields: [userId], references: [id])
  title     String?         @db.VarChar(255)
  createdAt DateTime        @default(now()) @map("created_at")
  messages  AiChatMessage[]

  @@map("ai_chats")
}

model AiChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  chatId    String   @map("chat_id") @db.Uuid
  chat      AiChat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role      String   @db.VarChar(20)
  content   String
  model     String?  @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ai_chat_messages")
}
